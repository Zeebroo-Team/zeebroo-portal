APP_NAME=Zeebroo
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# SociBiz AI Agent (Gemini). Get a key from https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
# Native image models: e.g. gemini-2.5-flash-image, gemini-3.1-flash-image-preview (see Google AI docs).
GEMINI_LOGO_IMAGE_MODEL=gemini-2.5-flash-image
GEMINI_LOGO_GENERATION_TIMEOUT=120
# Optional (supported image models only): 1:1, 3:2, etc. and 512, 1K, 2K, 4K
# GEMINI_LOGO_IMAGE_ASPECT_RATIO=1:1
# GEMINI_LOGO_IMAGE_SIZE=1K
GEMINI_MODEL=gemini-2.0-flash
GEMINI_TIMEOUT=60
GEMINI_MAX_TOOL_ROUNDS=16
# Gemini-native reply audio (optional second generateContent via a TTS model). Requires a TTS-capable model slug from Google docs.
GEMINI_REPLY_AUDIO=false
GEMINI_TTS_MODEL=gemini-2.5-flash-preview-tts
GEMINI_TTS_VOICE=Kore
GEMINI_TTS_SAMPLE_RATE=24000
# Maximum decoded microphone upload per message (~4 MiB default).
GEMINI_AUDIO_INPUT_MAX_BYTES=4194304

# Google OAuth (App connections — https://console.cloud.google.com/apis/credentials)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI="${APP_URL}/settings/app-connections/google/callback"
# Sign-in / sign-up (add this exact Authorized redirect URI in the same Google OAuth client)
GOOGLE_AUTH_REDIRECT_URI="${APP_URL}/auth/google/callback"
# Google Business Profile (My Business API). Enable Business Information API + Account Management API in GCP, add OAuth scope, reconnect with consent after turning on:
# GOOGLE_BUSINESS_PROFILE_SCOPE=true
# First reconnect after enabling: GOOGLE_OAUTH_PROMPT=consent (then revert to select_account if you prefer)
GOOGLE_BUSINESS_PROFILE_SCOPE=false
GOOGLE_OAUTH_PROMPT=select_account

VITE_APP_NAME="${APP_NAME}"
